                <h3 className="font-bold text-white tracking-tight">
                  {selectedNotif.title}
                </h3>
              </div>

              <div className="space-y-4 text-sm text-gray-400">
                <div>
                  <h4 className="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Details</h4>
