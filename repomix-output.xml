                  onClick={() => setDelBtnColor(color)}
                  className={`w-7 h-7 rounded-full border transition-all active:scale-90 cursor-pointer ${
                    delBtnColor === color ? 'ring-2 ring-emerald-500 ring-offset-2 scale-105' : 'border-gray-200'
                  }`}
